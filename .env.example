BOT_TOKEN=
OWNER_TELEGRAM_ID=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/content_bot
# Ключ AITunnel (sk-aitunnel-...) или прямой ключ Anthropic (sk-ant-...)
ANTHROPIC_API_KEY=
# Прокси AITunnel (Anthropic-совместимый). Для прямого Anthropic оставьте пустым.
ANTHROPIC_BASE_URL=https://api.aitunnel.ru
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-5
DEFAULT_CHANNEL_ID=
APP_HOST=0.0.0.0
APP_PORT=8000
TIMEZONE=Europe/Moscow
DAILY_CHECK_TIME=10:00

# polling — для локальной разработки, webhook — для Render/прода
BOT_MODE=polling
# Публичный базовый URL приложения (только для BOT_MODE=webhook), например https://content-bot.onrender.com
WEBHOOK_URL=
# Секретная часть пути webhook, произвольная строка
WEBHOOK_SECRET=change-me
# ID админов через запятую для первичного заполнения (создаются один раз)
SEED_ADMIN_IDS=
